{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/**": "allow"
    },
    "read": {
      "/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow"
    }
  },
  "theme": "catppuccin",
  "model": "openai/gpt-5.4",
  "plugin": [
    "@mohak34/opencode-notifier@0.1.34",
    "oh-my-opencode-slim@1.0.7",
    "btw-opencode@0.0.1"
  ],
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "formatter": {
    "biome": {
      "disabled": true
    },
    "prettier": {
      "disabled": true
    }
  }
}
