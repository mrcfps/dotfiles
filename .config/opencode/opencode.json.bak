{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/**": "allow"
    },
    "read": {
      "/**": "allow"
    },
    "edit": {
      "/tmp/**": "allow"
    }
  },
  "theme": "catppuccin",
  "model": "openai/gpt-5.4",
  "default_agent": "build",
  "plugin": [
    "@mohak34/opencode-notifier@0.1.34",
    "oh-my-opencode-slim"
  ],
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  }
}
